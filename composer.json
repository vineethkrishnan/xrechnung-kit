{
    "name": "vineethkrishnan/xrechnung-kit-dev",
    "description": "Development workspace for xrechnung-kit. Each sub-package under core/, kosit-bundle/, cli/, adapters/*, and mappers/* publishes to Packagist independently as vineethkrishnan/xrechnung-kit-*.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "phpstan/phpstan": "^1.11 || ^2.0",
        "phpstan/extension-installer": "^1.4",
        "vimeo/psalm": "^6.0",
        "friendsofphp/php-cs-fixer": "^3.59",
        "roave/security-advisories": "dev-latest",
        "vineethkrishnan/xrechnung-kit-core": "@dev"
    },
    "repositories": [
        { "type": "path", "url": "core", "options": { "symlink": true } }
    ],
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=1G",
        "psalm": "psalm",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "kosit": "@php cli/validate-kosit corpus core/tests/Fixtures",
        "qa": ["@cs", "@stan", "@psalm", "@test"]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit across the workspace",
        "stan": "Run PHPStan at the configured level",
        "psalm": "Run Psalm at level 1",
        "cs": "Check code style (dry-run)",
        "cs-fix": "Apply code style fixes",
        "kosit": "Validate the fixture corpus with KoSIT Schematron (requires Java 17+)",
        "qa": "Run cs, stan, psalm, test in order"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "composer/package-versions-deprecated": true
        }
    }
}
