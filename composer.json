{
    "name": "vineethkrishnan/xrechnung-kit-dev",
    "description": "Development workspace for xrechnung-kit. Each sub-package under core/, kosit-bundle/, cli/, adapters/*, and mappers/* publishes to Packagist independently as vineethkrishnan/xrechnung-kit-*.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "phpstan/phpstan": "^1.11 || ^2.0",
        "phpstan/extension-installer": "^1.4",
        "vimeo/psalm": "^6.0",
        "friendsofphp/php-cs-fixer": "^3.59",
        "phpbench/phpbench": "^1.2",
        "roave/security-advisories": "dev-latest",
        "vineethkrishnan/xrechnung-kit-core": "@dev",
        "vineethkrishnan/xrechnung-kit-cli": "@dev",
        "vineethkrishnan/xrechnung-kit-kosit-bundle": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "core",
            "options": {
                "symlink": true,
                "versions": { "vineethkrishnan/xrechnung-kit-core": "0.1.0" }
            }
        },
        {
            "type": "path",
            "url": "cli",
            "options": {
                "symlink": true,
                "versions": { "vineethkrishnan/xrechnung-kit-cli": "0.1.0" }
            }
        },
        {
            "type": "path",
            "url": "kosit-bundle",
            "options": {
                "symlink": true,
                "versions": { "vineethkrishnan/xrechnung-kit-kosit-bundle": "0.1.0" }
            }
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "XrechnungKit\\Tests\\": "core/tests/",
            "XrechnungKit\\Benchmarks\\": "benchmarks/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=1G",
        "psalm": "psalm",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "kosit": "validate-kosit core/tests/Fixtures",
        "benchmark": "phpbench run --report=aggregate",
        "qa": ["@cs", "@stan", "@psalm", "@test"]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit across the workspace",
        "stan": "Run PHPStan at the configured level",
        "psalm": "Run Psalm at level 1",
        "cs": "Check code style (dry-run)",
        "cs-fix": "Apply code style fixes",
        "kosit": "Validate the fixture corpus with KoSIT Schematron (requires Java 17+)",
        "benchmark": "Run PHPBench suites under benchmarks/ with the aggregate report",
        "qa": "Run cs, stan, psalm, test in order"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "composer/package-versions-deprecated": true
        }
    }
}
