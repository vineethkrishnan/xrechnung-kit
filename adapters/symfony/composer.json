{
    "name": "vineethkrishnan/xrechnung-kit-symfony",
    "description": "Symfony bundle for xrechnung-kit. Wires the framework-agnostic core into Symfony's DI container, logger, and messenger.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["xrechnung", "en16931", "e-invoicing", "symfony", "symfony-bundle", "germany"],
    "homepage": "https://github.com/vineethkrishnan/xrechnung-kit",
    "support": {
        "issues": "https://github.com/vineethkrishnan/xrechnung-kit/issues",
        "source": "https://github.com/vineethkrishnan/xrechnung-kit",
        "docs": "https://github.com/vineethkrishnan/xrechnung-kit/blob/main/docs/frameworks/symfony.md"
    },
    "authors": [
        { "name": "Vineeth N K", "email": "me@vineethnk.in", "role": "Maintainer" }
    ],
    "require": {
        "php": "^8.1",
        "symfony/config": "^6.0 || ^7.0",
        "symfony/dependency-injection": "^6.0 || ^7.0",
        "symfony/http-kernel": "^6.0 || ^7.0",
        "symfony/messenger": "^6.0 || ^7.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "vineethkrishnan/xrechnung-kit-core": "^0.1 || ^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "symfony/framework-bundle": "^6.0 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "XrechnungKit\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "XrechnungKit\\Symfony\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
