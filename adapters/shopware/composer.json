{
    "name": "vineethkrishnan/xrechnung-kit-shopware",
    "description": "Shopware 6 plugin for xrechnung-kit. Wires the framework-agnostic core into Shopware's Symfony DI, logging, and order workflow events.",
    "type": "shopware-platform-plugin",
    "license": "MIT",
    "keywords": ["xrechnung", "en16931", "e-invoicing", "shopware", "shopware6", "shopware-plugin", "germany"],
    "homepage": "https://github.com/vineethkrishnan/xrechnung-kit",
    "support": {
        "issues": "https://github.com/vineethkrishnan/xrechnung-kit/issues",
        "source": "https://github.com/vineethkrishnan/xrechnung-kit",
        "docs": "https://xrechnung-kit.vineethnk.in/frameworks/shopware"
    },
    "authors": [
        { "name": "Vineeth N K", "email": "me@vineethnk.in", "role": "Maintainer" }
    ],
    "require": {
        "php": "^8.1",
        "shopware/core": "~6.5.0 || ~6.6.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "vinelabs-de/xrechnung-kit": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "symfony/http-client": "^6.0 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "Vineethkrishnan\\XrechnungKitShopware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vineethkrishnan\\XrechnungKitShopware\\Tests\\": "tests/"
        }
    },
    "extra": {
        "shopware-plugin-class": "Vineethkrishnan\\XrechnungKitShopware\\XrechnungKitShopware",
        "label": {
            "en-GB": "xrechnung-kit",
            "de-DE": "xrechnung-kit"
        },
        "description": {
            "en-GB": "Generate KoSIT-strict XRechnung 3.0 invoices from Shopware orders.",
            "de-DE": "KoSIT-strenge XRechnung 3.0 Rechnungen aus Shopware-Bestellungen erzeugen."
        },
        "manufacturerLink": {
            "en-GB": "https://xrechnung-kit.vineethnk.in/"
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
