<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
               https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false"/>

        <!-- DAL definition -->
        <service id="Vineethkrishnan\XrechnungKitShopware\Core\Content\XrechnungInvoice\XrechnungInvoiceDefinition">
            <tag name="shopware.entity.definition" entity="xrechnung_kit_invoice"/>
        </service>

        <!-- Core kit services -->
        <service id="XrechnungKit\XRechnungValidator" public="true"/>

        <!-- Plugin lifecycle: custom field set installer -->
        <service id="Vineethkrishnan\XrechnungKitShopware\Service\CustomFieldSetInstaller" public="true">
            <argument type="service" id="custom_field_set.repository"/>
        </service>

        <!-- Typed plugin config wrapper -->
        <service id="Vineethkrishnan\XrechnungKitShopware\Service\PluginConfig">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <!-- Plugin orchestrator -->
        <service id="Vineethkrishnan\XrechnungKitShopware\Service\XrechnungService" public="true">
            <argument type="service" id="XrechnungKit\XRechnungValidator"/>
            <argument type="service" id="logger"/>
        </service>

        <!-- Order to MappingData mapper -->
        <service id="Vineethkrishnan\XrechnungKitShopware\Service\OrderToMappingData" public="true">
            <argument type="service" id="Vineethkrishnan\XrechnungKitShopware\Service\PluginConfig"/>
        </service>

        <!-- Order state subscriber that triggers generation -->
        <service id="Vineethkrishnan\XrechnungKitShopware\Subscriber\OrderStateChangedSubscriber">
            <argument type="service" id="Vineethkrishnan\XrechnungKitShopware\Service\OrderToMappingData"/>
            <argument type="service" id="Vineethkrishnan\XrechnungKitShopware\Service\XrechnungService"/>
            <argument type="service" id="order.repository"/>
            <argument type="service" id="xrechnung_kit_invoice.repository"/>
            <argument type="service" id="Vineethkrishnan\XrechnungKitShopware\Service\PluginConfig"/>
            <argument type="service" id="logger"/>
            <argument>%kernel.project_dir%</argument>
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
