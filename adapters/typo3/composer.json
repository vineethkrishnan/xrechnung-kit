{
    "name": "vineethkrishnan/xrechnung-kit-typo3",
    "description": "TYPO3 extension for xrechnung-kit. Wires the framework-agnostic core into TYPO3's Symfony DI container, logging, and scheduler.",
    "type": "typo3-cms-extension",
    "license": "MIT",
    "keywords": ["xrechnung", "en16931", "e-invoicing", "typo3", "typo3-extension", "germany"],
    "homepage": "https://github.com/vineethkrishnan/xrechnung-kit",
    "support": {
        "issues": "https://github.com/vineethkrishnan/xrechnung-kit/issues",
        "source": "https://github.com/vineethkrishnan/xrechnung-kit",
        "docs": "https://xrechnung-kit.vineethnk.in/frameworks/typo3"
    },
    "authors": [
        { "name": "Vineeth N K", "email": "me@vineethnk.in", "role": "Maintainer" }
    ],
    "require": {
        "php": "^8.1",
        "typo3/cms-core": "^11.5 || ^12.4 || ^13.0",
        "typo3/cms-extbase": "^11.5 || ^12.4 || ^13.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "vinelabs-de/xrechnung-kit": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "typo3/testing-framework": "^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Vineethkrishnan\\XrechnungKitTypo3\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vineethkrishnan\\XrechnungKitTypo3\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "xrechnung_kit"
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "typo3/cms-composer-installers": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
