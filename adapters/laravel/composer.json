{
    "name": "vineethkrishnan/xrechnung-kit-laravel",
    "description": "Laravel adapter for xrechnung-kit. Wires the framework-agnostic core into Laravel's container, log stack, and queue.",
    "type": "library",
    "license": "MIT",
    "keywords": ["xrechnung", "en16931", "e-invoicing", "laravel", "germany"],
    "homepage": "https://github.com/vinelabs-de/xrechnung-kit",
    "support": {
        "issues": "https://github.com/vinelabs-de/xrechnung-kit/issues",
        "source": "https://github.com/vinelabs-de/xrechnung-kit",
        "docs": "https://xrechnung-kit.vineethnk.in/frameworks/laravel"
    },
    "authors": [
        { "name": "Vineeth N K", "email": "me@vineethnk.in", "role": "Maintainer" }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/queue": "^10.0 || ^11.0 || ^12.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "vinelabs-de/xrechnung-kit": "^0.1 || ^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "XrechnungKit\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "XrechnungKit\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "XrechnungKit\\Laravel\\XrechnungKitServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
