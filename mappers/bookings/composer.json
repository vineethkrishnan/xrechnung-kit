{
    "name": "vineethkrishnan/xrechnung-kit-mapper-bookings",
    "description": "Generic booking-shape mapper for xrechnung-kit. Genericised from Locaboo's booking invoice mapper; consumers plug their domain model in via the BookingShapeAdapter SPI.",
    "type": "library",
    "license": "MIT",
    "keywords": ["xrechnung", "en16931", "e-invoicing", "mapper", "bookings"],
    "homepage": "https://github.com/vineethkrishnan/xrechnung-kit",
    "support": {
        "issues": "https://github.com/vineethkrishnan/xrechnung-kit/issues",
        "source": "https://github.com/vineethkrishnan/xrechnung-kit",
        "docs": "https://github.com/vineethkrishnan/xrechnung-kit/blob/main/docs/mapping-data.md"
    },
    "authors": [
        { "name": "Vineeth N K", "email": "me@vineethnk.in", "role": "Maintainer" }
    ],
    "require": {
        "php": "^8.1",
        "vineethkrishnan/xrechnung-kit-core": "^0.1 || ^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "XrechnungKit\\Mapper\\Bookings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "XrechnungKit\\Mapper\\Bookings\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
